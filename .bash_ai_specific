# shellcheck shell=bash
# vi: set ft=sh:
source "$HOME/.bash_lima_specific"
export CLAUDE_VM_NAME="${CLAUDE_VM_NAME:-claude-vm}"
export CLAUDE_VM_TEMPLATE="${CLAUDE_VM_TEMPLATE:-$HOME/src/setup/lima-machines/claude.yaml}"
# shellcheck disable=SC2155
export CLAUDE_WHITELISTED_DIRECTORIES="$(cat <<-EOF
$HOME/src
EOF
)"
export CLAUDE_SSH_HOSTS_FROM_CONFIG="$(cat <<-EOF
github.carlosnunez.me
EOF
)"

claude() {
  _claude_limactl_shell() {
    limactl shell "$@" 2> >(grep -Ev "^OK$" >&2)
  }

  _generate_ssh_config_for_vm() {
    local config
    config=""
    for host in $CLAUDE_SSH_HOSTS_FROM_CONFIG
    do
      test -z "$host" && continue
      options=$(comm -13 <(ssh -G foo | sort) <(ssh -G "$host" | sort) |
        grep -Ev '^host ' |
        sed -E 's/^/  /')
      if test -z "$options"
      then
        log_warning "No SSH options found for host '$host'! Skipping."
        continue
      fi
      partial="$(cat <<-EOF
Host $host
$options
EOF
)"
      config="$config\n$partial"
    done
    test -z "$config" && return 1
    echo -e "$config"
  }

  _generate_ssh_keys_for_vm() {
    local keys
    keys=""
    for host in $CLAUDE_SSH_HOSTS_FROM_CONFIG
    do
      test -z "$host" && continue
      want_keyname="$(ssh -G "$host" |
        grep -E '^identityfile' |
        cut -f2 -d ' ' |
        sed "s;~;$HOME;g")"
      if test -z "$want_keyname" || ! test -e "$want_keyname"
      then
        log_warning "No SSH key found for host '$host'! Skipping."
        continue
      fi
      this_key="${want_keyname};$(base64 -w 0 < "$want_keyname")"
      keys="${keys}\n${this_key}"
    done
    test -z "$keys" && return 1
    echo -e "$keys"
  }

  _skip_whitelisting() {
    grep -E '^true$' <<< "$CLAUDE_SKIP_WHITELISTING"
  }

  _pwd_is_whitelisted() {
    for dir in $CLAUDE_WHITELISTED_DIRECTORIES
    do
      if test "$dir" == "$PWD"
      then
        log_warning "Directory '$PWD' is whitelisted but is not a sub-directory of this folder."
        return 1
      fi
      grep -q "$dir" <<< "$PWD" && return 0
    done
    return 1
  }

  _create_and_start_claude_vm() {
    log_info "Creating and starting Claude VM"
    lima_create_vm_quiet "$CLAUDE_VM_TEMPLATE" "$CLAUDE_VM_NAME" && lima_start_vm "$CLAUDE_VM_NAME"
  }

  _run_claude() {
    if ! _pwd_is_whitelisted
    then
      if ! _skip_whitelisting
      then
        log_error "Directory '$PWD' hasn't been whitelisted; add it \
to $CLAUDE_WHITELISTED_DIRECTORIES in '$HOME/.bash_ai_specific' and try again."
        return 1
      else log_error "Directory '$PWD' hasn't been whitelisted; proceed with caution! (Add it \
  to $CLAUDE_WHITELISTED_DIRECTORIES in '$HOME/.bash_ai_specific' if this directory is safe)."
      fi
    fi
    _claude_limactl_shell --workdir "$PWD" "${CLAUDE_VM_NAME}" -- claude --dangerously-skip-permissions "$@"
  }

  _sync_config_dir_from_claude_vm() {
    log_info "Syncing Claude settings from Claude VM to local machine"
    limactl cp -r "${CLAUDE_VM_NAME}:"'~/.claude/' "$HOME/.config/claude/" &&
      limactl cp -r "${CLAUDE_VM_NAME}:"'~/.claude.json' "$HOME/.config/claude/" &&
      rm -rf "$HOME/.config/claude/{markdowns,rules,skills}"
  }

  _sync_config_dir_to_claude_vm_if_first_boot() {
    _claude_limactl_shell "$CLAUDE_VM_NAME" sh -c 'test -f /ready_for_claude' && return 0
    log_info "Syncing saved Claude preferences to VM"
    tarball=$(mktemp "${TMPDIR:-/tmp}/claude-sync-XXXXX.tar.gz")
    tar --exclude './rules' --exclude './skills' --exclude './markdowns' \
      -czf "$tarball" -C "$HOME/.config/claude" . &&
      limactl cp "$tarball" "${CLAUDE_VM_NAME}:/tmp/claude-data.tar.gz" &&
      _claude_limactl_shell "$CLAUDE_VM_NAME" sh -c 'tar -xf /tmp/claude-data.tar.gz -C ~/.claude' &&
      _claude_limactl_shell "$CLAUDE_VM_NAME" sh -c 'mv ~/.claude/.claude.json ~/.claude.json' &&
      rm -f "$tarball"
  }

  _set_up_gpg_keys() {
    if test -z "$CLAUDE_REGENERATE_GPG_KEYS"
    then _claude_limactl_shell "$CLAUDE_VM_NAME" sh -c 'test -f ~/.claude/.gpg_keys_done' && return 0
    fi
    keys="$(tr ',' '\n' <<< "$CLAUDE_GPG_KEY_NAMES" | sed -E 's/,$//')"
    test -z "$keys" && keys=$(gpg --list-keys --with-colons |
      grep 'uid' |
      cut -f10 -d ':')
    log_info "Importing GPG keys on this system into the Claude VM: $(tr '\n' ',' <<< "$keys") \
(You'll be asked to enter your passphrases multiple times.)"
    for key in $keys
    do
      # Looks like I can't open /dev/tty if limactl shell is called from within a function.
      gpg --export-secret-keys --armor "$key" | _claude_limactl_shell "$CLAUDE_VM_NAME" sh -c 'cat - > /tmp/gpg_key' &&
        limactl shell --tty "$CLAUDE_VM_NAME" sh -c 'gpg --pinentry-mode loopback --import  < /tmp/gpg_key'
    done || return 1
    _claude_limactl_shell "$CLAUDE_VM_NAME" sh -c 'rm /tmp/gpg_key && touch ~/.claude/.gpg_keys_done'
  }

  _set_up_ssh_config() {
    log_info "Setting up SSH config in Claude VM"
    if ! config=$(_generate_ssh_config_for_vm)
    then
      log_warning "Couldn't create an SSH config to upload into the VM. Pushing into remote Git \
services and other operations won't work!"
    fi
    echo "$config" | _claude_limactl_shell "$CLAUDE_VM_NAME" sh -c 'cat - > ~/.ssh/config'
  }

  _add_ssh_keys() {
    log_info "Adding SSH keys to Claude VM"
    if ! keys=$(_generate_ssh_keys_for_vm)
    then
      log_warning "Couldn't create SSH keys to upload into the VM. Pushing into remote Git \
services and other operations won't work!"
    fi
    echo "$keys" |
      while read -r kvp
      do
        key_name="$(cut -f1 -d ';' <<< "$kvp")"
        test -z "$key_name" && continue
        key_enc=$(cut -f2 -d ';' <<< "$kvp")
        if test -z "$key_enc"
        then
          log_warning "Key '$key_name' is blank and cannot be added. Skipping."
          continue
        fi
        base64 -d <<< "$key_enc" | _claude_limactl_shell "$CLAUDE_VM_NAME" sh -c 'cat - > ~/.ssh/'"$(basename "$key_name")"
      done
  }

  _set_up_github_token() {
    if test -z "$GITHUB_TOKEN" && ! >/dev/null which gh
    then
      log_warning "Unable to find a GitHub token or the 'gh' utility on this system. GitHub interactions won't work from within the VM!"
      return 0
    fi
    token=$(gh auth token 2>/dev/null)
    if test -z "$token"
    then
      log_warning "Couldn't retrieve an active GitHub token. Make sure to run 'gh auth login' first."
      return 0
    fi
    _claude_limactl_shell "$CLAUDE_VM_NAME" sh -c "echo '$token' > ~/.tokens/github"

  }

  _add_cc_token() {
    local token
    token="$(_claude_limactl_shell "$CLAUDE_VM_NAME" sh -c 'test -f ~/.tokens/claude_code && \
      cat ~/.tokens/claude_code')"
    test -n "$token" && return 0

    if test -z "$CLAUDE_1PASSWORD_NAME" || test -z "$CLAUDE_1PASSWORD_VAULT"
    then
      log_error "CLAUDE_1PASSWORD_NAME or CLAUDE_1PASSWORD_VAULT is not defined in the environment. \
These are needed to retrieve your Claude Code OAuth token from 1Password.

Define them in a dotfile somewhere and try again."
      return 1
    fi
    log_info "Retrieving Claude Code API token from 1Password \
[key: $CLAUDE_1PASSWORD_NAME, vault: $CLAUDE_1PASSWORD_VAULT]"
    token="$(op_get_password_by_name "$CLAUDE_1PASSWORD_NAME" "$CLAUDE_1PASSWORD_VAULT")"
    if test -z "$token" || test "${token,,}" == 'no password found'
    then
      log_error "Failed to get Claude token; see error messages above."
      return 1
    fi
    _claude_limactl_shell "$CLAUDE_VM_NAME" sh -c "echo '$token' > ~/.tokens/claude_code"
  }

  _mark_claude_ready() {
    _claude_limactl_shell --tty "$CLAUDE_VM_NAME" sh -c 'sudo touch /ready_for_claude'
  }

  _skip_cc_onboarding() {
    _claude_limactl_shell "$CLAUDE_VM_NAME" sh -c 'test -f ~/.claude.json' && return 0

    log_info "Skipping Claude Code onboarding"
    _claude_limactl_shell "$CLAUDE_VM_NAME" \
      sh -c 'echo "{\"hasCompletedOnboarding\": true}" > ~/.claude.json'
  }

  local rc
    _create_and_start_claude_vm &&
    _add_cc_token &&
    _set_up_github_token &&
    _set_up_gpg_keys &&
    _set_up_ssh_config &&
    _add_ssh_keys &&
    _sync_config_dir_to_claude_vm_if_first_boot &&
    _skip_cc_onboarding &&
    _mark_claude_ready &&
    _run_claude "$@" &&
    rc="$?" &&
    _sync_config_dir_from_claude_vm &&
    return "$rc"
}

claude_dangerously() {
  CLAUDE_SKIP_WHITELISTING=true claude "$@"
}
